# Copy to .env for local development
# On Render, set via the dashboard or render.yaml generateValue: true

# Token that the frontend sends in the X-Api-Token header.
# Must match the DWG_EXPORT_TOKEN in backend-client.js.
API_TOKEN=change_me

# Comma-separated list of sites allowed to call this service (CORS).
# Use "*" for testing, then lock to your real domain(s) for production, e.g.:
# ALLOWED_ORIGINS=https://mei-hagalil-gis.vercel.app
ALLOWED_ORIGINS=*
